{
  "name": "rare-platform-kit-ts",
  "private": true,
  "version": "0.1.0",
  "description": "Rare Platform Kit monorepo for TypeScript third-party platform integration",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "demo:register:challenge": "pnpm --filter @rare-id/platform-kit-demo... build && node ./packages/platform-kit-demo/dist/register-challenge-cli.js",
    "demo:register:complete": "pnpm --filter @rare-id/platform-kit-demo... build && node ./packages/platform-kit-demo/dist/register-complete-cli.js",
    "demo:start": "pnpm --filter @rare-id/platform-kit-demo... build && node ./packages/platform-kit-demo/dist/server-cli.js",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:eslint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "format": "biome check --write .",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.28.1",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.7"
  }
}
